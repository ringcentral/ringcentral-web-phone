{
  "name": "ringcentral-web-phone",
  "version": "2.4.4",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ringcentral/ringcentral-web-phone.git"
  },
  "license": "MIT",
  "types": "dist/index.d.mts",
  "module": "dist/index.mjs",
  "main": "dist/index.cjs",
  "files": [
    "dist"
  ],
  "targets": {
    "types": false
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./*": {
      "import": {
        "types": "./dist/*.d.mts",
        "default": "./dist/*.mjs"
      },
      "require": {
        "types": "./dist/*.d.cts",
        "default": "./dist/*.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "format": "biome format --write .",
    "lint": "biome lint --write .",
    "check": "biome check . --write",
    "prepublishOnly": "pnpm build",
    "postpublish": "rm -rf dist",
    "serve": "rm -rf .parcel-cache && parcel serve test/index.html --no-hmr",
    "test": "NODE_OPTIONS=--require=dotenv-override-true/config playwright test --workers=1",
    "upgrade": "pnpm update --latest"
  },
  "dependencies": {
    "blueimp-md5": "^2.19.0",
    "fast-xml-parser": "^5.8.0",
    "sdp-transform": "^3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@playwright/test": "^1.60.0",
    "@types/blueimp-md5": "^2.18.2",
    "@types/node": "^25.9.3",
    "@types/sdp-transform": "^2.15.0",
    "buffer": "^6.0.3",
    "dotenv-override-true": "^6.2.2",
    "events": "^3.3.0",
    "manate": "^2.0.3",
    "parcel": "^2.16.4",
    "process": "^0.11.10",
    "stream-browserify": "^3.0.0",
    "string_decoder": "^1.3.0",
    "timers-browserify": "^2.0.12",
    "tsdown": "^0.21.10",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "wait-for-async": "^0.8.1"
  },
  "packageManager": "pnpm@10.33.1"
}
