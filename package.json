{
  "name": "ringcentral-web-phone",
  "version": "2.4.2",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ringcentral/ringcentral-web-phone.git"
  },
  "license": "MIT",
  "types": "dist/esm/index.d.ts",
  "module": "dist/esm/index.js",
  "main": "dist/cjs/index.cjs",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./*": {
      "types": "./dist/esm/*.d.ts",
      "import": "./dist/esm/*.js",
      "require": "./dist/cjs/*.cjs"
    },
    "./*/*": {
      "types": "./dist/esm/*/*.d.ts",
      "import": "./dist/esm/*/*.js",
      "require": "./dist/cjs/*/*.cjs"
    },
    "./*/*/*": {
      "types": "./dist/esm/*/*/*.d.ts",
      "import": "./dist/esm/*/*/*.js",
      "require": "./dist/cjs/*/*/*.cjs"
    }
  },
  "scripts": {
    "build": "tsdown && tsc -p tsconfig.json --emitDeclarationOnly",
    "format": "biome format --write .",
    "lint": "biome lint --write .",
    "check": "biome check . --write",
    "prepublishOnly": "yarn build",
    "postpublish": "rm -rf dist",
    "serve": "rm -rf .parcel-cache && parcel test/index.html --no-hmr",
    "test": "NODE_OPTIONS=--require=dotenv-override-true/config playwright test --workers=1"
  },
  "dependencies": {
    "blueimp-md5": "^2.19.0",
    "fast-xml-parser": "^5.7.2",
    "sdp-transform": "^3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@playwright/test": "^1.59.1",
    "@types/blueimp-md5": "^2.18.2",
    "@types/node": "^25.6.0",
    "@types/sdp-transform": "^2.15.0",
    "buffer": "^6.0.3",
    "dotenv-override-true": "^6.2.2",
    "events": "^3.3.0",
    "manate": "^2.0.3",
    "parcel": "^2.16.4",
    "process": "^0.11.10",
    "stream-browserify": "^3.0.0",
    "string_decoder": "^1.3.0",
    "timers-browserify": "^2.0.12",
    "tsdown": "^0.21.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "wait-for-async": "^0.8.1",
    "yarn-upgrade-all": "^0.8.1"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
